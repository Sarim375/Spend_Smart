@{
    ViewData["Title"] = "SpendSmart Dashboard";
}

<div class="container py-5">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
        <div class="container-fluid py-5 text-center">
            <h1 class="display-5 fw-bold text-primary mb-3">Welcome to SpendSmart</h1>
            <p class="col-md-8 mx-auto fs-5 text-muted">
                A simple and intuitive personal expense tracking application. Manage your daily budget, categorize spending patterns, and maintain complete control of your financial records.
            </p>
            <div class="d-flex justify-content-center gap-3 mt-4">
                <a asp-controller="Home" asp-action="Expenses" class="btn btn-primary btn-lg px-4 shadow-sm">
                    <i class="bi bi-list-task"></i> View Expenses
                </a>
                <a asp-controller="Home" asp-action="CreateEditExpense" class="btn btn-success btn-lg px-4 shadow-sm">
                    <i class="bi bi-plus-circle"></i> Add New Expense
                </a>
            </div>
        </div>
    </div>
</div>

