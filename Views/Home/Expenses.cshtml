@model IEnumerable<SpendSmart.Models.Expense>

@{
    ViewData["Title"] = "Expenses List";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary font-weight-bold mb-0">Logged Expenses</h2>
        <a asp-controller="Home" asp-action="CreateEditExpense" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Add New Expense
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info shadow-sm text-center py-4">
            <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
            <span>No expenses recorded yet. Click <strong>Add New Expense</strong> to get started!</span>
        </div>
    }
    else
    {
        <div class="card shadow border-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" style="width: 10%;">ID</th>
                            <th scope="col" style="width: 50%;">Description</th>
                            <th scope="col" style="width: 20%; text-align: right;">Amount</th>
                            <th scope="col" style="width: 20%; text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var expense in Model)
                        {
                            <tr>
                                <td><span class="text-muted fw-bold">#@expense.Id</span></td>
                                <td><strong>@expense.Description</strong></td>
                                <td style="text-align: right;" class="text-danger fw-bold">$@expense.Value.ToString("N2")</td>
                                <td style="text-align: center;">
                                    <div class="btn-group" role="group">
                                        <a asp-controller="Home" asp-action="CreateEditExpense" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                            Edit
                                        </a>
                                        <a asp-controller="Home" asp-action="DeleteExpense" asp-route-id="@expense.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this expense?');" title="Delete">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-secondary">
                        <tr class="fw-bold">
                            <td colspan="2" class="text-end">Total Spending:</td>
                            <td style="text-align: right;" class="text-danger fs-5">$@Model.Sum(e => e.Value).ToString("N2")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            Back to Dashboard
        </a>
    </div>
</div>

