@model SpendSmart.Models.Expense

@{
    ViewData["Title"] = Model.Id == 0 ? "Create Expense" : "Edit Expense";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h3 class="mb-0">@(Model.Id == 0 ? "Add New Expense" : "Edit Expense")</h3>
        </div>
        <div class="card-body p-4">
            <form asp-controller="Home" asp-action="CreateEditExpenseForm" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Value" class="form-label fw-bold">Value ($)</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input class="form-control" type="number" placeholder="0.00" asp-for="Value" step="0.01" required />
                    </div>
                    <span asp-validation-for="Value" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <input class="form-control" type="text" placeholder="e.g. Groceries, Electric Bill, Gas" asp-for="Description" required />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-success px-4" type="submit">
                        <i class="bi bi-check-circle"></i> Save
                    </button>
                    <a asp-controller="Home" asp-action="Expenses" class="btn btn-secondary px-4">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

